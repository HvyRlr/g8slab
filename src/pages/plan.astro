---
import Page from '../layouts/Page.astro';

const phases = [
  {
    date: 'May 8',
    title: 'Pre-Dry Run',
    duration: '1 day',
    color: 'purple',
    tasks: ['Backup strategy', 'Deploy g8slab.com → Vercel', 'Interviewer housekeeping', 'Seed examples library'],
    highlight: [0],
    warning: null,
  },
  {
    date: 'May 11',
    title: 'Dry Run',
    duration: '1 day',
    color: 'blue',
    tasks: ['Subject research', 'AI Discovery interview', 'Capture learnings'],
    highlight: [1],
    warning: null,
  },
  {
    date: 'May 12–14',
    title: 'Post-Dry Run',
    duration: '3 days',
    color: 'green',
    tasks: ['Wire KB → pipeline', 'Fix L&R relevance hardcoding', 'Add retry/error handling', 'Fix absolute paths', 'Update portfolio content', 'Cancel Adzuna'],
    highlight: [0],
    warning: null,
  },
  {
    date: 'May 15–28',
    title: 'Software Factory Phase 1',
    duration: '10 days · 46 hrs',
    color: 'orange',
    tasks: ['Spec sub-agent', 'Architect sub-agent', 'Builder sub-agent', 'Test sub-agent', 'Critic sub-agent', 'Orchestration + human gates', 'Integration testing'],
    highlight: [0, 1, 2, 3, 4],
    warning: 'Token-heavy — split sessions; consider API key mode',
  },
  {
    date: 'Jun 2–6',
    title: 'Token Limit Buffer',
    duration: '1 week',
    color: 'yellow',
    tasks: ['SF overflow / refinement', 'Wire Upwork API (if key arrived)', 'Extra dry runs'],
    highlight: [],
    warning: null,
    buffer: true,
  },
  {
    date: 'Jun 9–11',
    title: 'Near-Term Backlog',
    duration: '3 days',
    color: 'teal',
    tasks: ['Build /domain-brief skill', 'Redesign ops dashboard', 'Requirements Gathering spec v0.3'],
    highlight: [0],
    warning: null,
  },
  {
    date: 'Jun 12–26',
    title: 'Phase 2 — Client-Facing Interview',
    duration: '11 days · 44 hrs',
    color: 'red',
    tasks: ['Astro SSR + Vercel adapter', 'Clerk auth (magic link)', 'API routes + streaming', 'Session state (Vercel KV)', 'Real-time chat UI', 'Interview flow management', 'Deliverable display', 'End-to-end testing'],
    highlight: [4],
    warning: 'Token-heavy — use API key mode for build sessions',
  },
];

const milestones = [
  { date: 'May 8',  label: 'Backup live\nSite deployed',       color: 'text-violet-400' },
  { date: 'May 11', label: 'Dry run\nconducted',               color: 'text-purple-400' },
  { date: 'May 12', label: 'KB injection\nlive',               color: 'text-emerald-400' },
  { date: 'May 28', label: 'SF Phase 1\ncomplete',             color: 'text-orange-400' },
  { date: 'Jun 11', label: 'Backlog\ncleared',                 color: 'text-blue-400' },
  { date: 'Jun 26', label: 'Client interview\nlive',           color: 'text-red-400' },
];

const colorMap: Record<string, { dot: string; card: string; title: string; date: string }> = {
  purple: { dot: 'bg-violet-500',  card: 'border-violet-800/50 bg-violet-950/20',  title: 'text-violet-300',  date: 'text-violet-400' },
  blue:   { dot: 'bg-blue-500',    card: 'border-blue-800/50 bg-blue-950/20',      title: 'text-blue-300',    date: 'text-blue-400' },
  green:  { dot: 'bg-emerald-500', card: 'border-emerald-800/50 bg-emerald-950/20',title: 'text-emerald-300', date: 'text-emerald-400' },
  orange: { dot: 'bg-orange-500',  card: 'border-orange-800/50 bg-orange-950/20',  title: 'text-orange-300',  date: 'text-orange-400' },
  yellow: { dot: 'bg-yellow-500',  card: 'border-yellow-800/40 bg-yellow-950/10',  title: 'text-yellow-300',  date: 'text-yellow-400' },
  teal:   { dot: 'bg-teal-500',    card: 'border-teal-800/50 bg-teal-950/20',      title: 'text-teal-300',    date: 'text-teal-400' },
  red:    { dot: 'bg-red-500',     card: 'border-red-800/50 bg-red-950/20',        title: 'text-red-300',     date: 'text-red-400' },
};

const deferred = ['Solution Designer', 'Domain Accelerator', 'Pipeline Orchestrator', 'Gig Search (blocked)', 'CPA Verifier', 'Timer App', 'Trainer', 'Photo Memory Builder'];
---

<Page title="Work Plan" description="AI Agency Pipeline build plan — phases, tasks, and milestones">

  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-5xl font-bold text-white mb-4">Work Plan</h1>
    <div class="flex items-center gap-6">
      <p class="text-lg text-gray-400">AI Agency Pipeline · 4 hrs/day Mon–Fri · Start May 8, 2026</p>
      <div class="flex gap-6 ml-auto text-right">
        <div>
          <div class="text-2xl font-bold text-violet-400">7</div>
          <div class="text-xs text-gray-500 uppercase tracking-widest">Phases</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-violet-400">Jun 26</div>
          <div class="text-xs text-gray-500 uppercase tracking-widest">Target</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute left-[88px] top-3 bottom-3 w-px bg-gradient-to-b from-violet-500 via-emerald-500 to-red-500 opacity-20"></div>

    <div class="space-y-3">
      {phases.map(phase => {
        const c = colorMap[phase.color];
        return (
          <div class="flex gap-6 items-start">
            <!-- Date -->
            <div class={`w-[88px] shrink-0 pt-3.5 text-right text-xs font-semibold uppercase tracking-wide leading-tight ${c.date} relative`}>
              {phase.date}
              <span class={`absolute -right-[27px] top-[14px] w-2.5 h-2.5 rounded-full border-2 border-gray-900 ${c.dot}`}></span>
            </div>

            <!-- Card -->
            <div class={`flex-1 border rounded-lg p-4 ${c.card} ${phase.buffer ? 'opacity-60 border-dashed' : ''}`}>
              <div class="flex items-baseline justify-between mb-3">
                <span class={`font-semibold text-sm ${c.title}`}>{phase.title}</span>
                <span class="text-xs text-gray-600">{phase.duration}</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {phase.tasks.map((task, i) => (
                  <span class={`text-xs px-2.5 py-1 rounded-full ${
                    phase.highlight.includes(i)
                      ? 'bg-white/10 text-gray-200'
                      : 'bg-white/5 text-gray-500'
                  }`}>{task}</span>
                ))}
              </div>
              {phase.warning && (
                <p class="mt-2.5 text-xs text-amber-500/80">⚠ {phase.warning}</p>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Milestones -->
  <div class="mt-10 pt-8 border-t border-gray-800">
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-600 mb-5">Milestones</p>
    <div class="relative">
      <div class="absolute left-0 right-0 top-[9px] h-px bg-gradient-to-r from-violet-500 via-emerald-500 to-red-500 opacity-20"></div>
      <div class="grid grid-cols-6 gap-2">
        {milestones.map(m => (
          <div class="text-center pt-5 relative">
            <span class={`absolute top-[4px] left-1/2 -translate-x-1/2 w-2.5 h-2.5 rounded-full ${m.color.replace('text-', 'bg-')}`}></span>
            <div class={`text-xs font-bold ${m.color}`}>{m.date}</div>
            <div class="text-xs text-gray-600 mt-0.5 leading-tight whitespace-pre-line">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Deferred -->
  <div class="mt-6 flex flex-wrap items-center gap-2 p-4 rounded-lg border border-gray-800/60 bg-gray-900/20">
    <span class="text-xs font-semibold uppercase tracking-widest text-gray-700 mr-2">Deferred / Ad-hoc</span>
    {deferred.map(item => (
      <span class="text-xs px-2.5 py-1 rounded-full bg-gray-800/40 text-gray-600">{item}</span>
    ))}
  </div>

  <!-- Footer note -->
  <p class="mt-6 text-xs text-gray-700 text-right">AI Agency Pipeline · HvyRlr · Updated May 8, 2026</p>

</Page>
