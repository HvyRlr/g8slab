---
import Page from '../layouts/Page.astro';

const projects = [
  {
    name: 'AI Discovery Interview',
    category: 'Interviewer',
    status: 'Live',
    description: 'Conducts a structured interview with a professional to identify where AI can add value to their role. Produces a prioritised AI Opportunity Map with specific opportunities, expected impact, constraints, and a 90-day action plan.',
    results: ['First live session: Project Manager role', '5 prioritised AI opportunities identified', 'Full Opportunity Map produced in one session'],
    tech: ['Claude Code', 'Anthropic API', 'Markdown specs'],
  },
  {
    name: 'Content Repurposing',
    category: 'Interviewer',
    status: 'Live',
    description: 'Interviews a client about their existing long-form content (webinars, videos, reports) and desired outputs, then generates a full Content Repurposing Package — LinkedIn posts, email sequences, ebooks, and more.',
    results: ['LinkedIn posts + 3-email nurture sequence from a single YouTube video', 'Subject Research: LinkedIn + company research before every session', 'Examples library for style-matched output'],
    tech: ['Claude Code', 'YouTube transcript API', 'Anthropic API'],
  },
  {
    name: 'Requirements Gathering',
    category: 'Interviewer',
    status: 'Live',
    description: 'Conducts a structured requirements discovery session for a technology product or feature. Produces a Requirements Document covering vision, feature definitions, platform constraints, and measurable success criteria.',
    results: ['First session: defined full scope for a mobile timer app', 'Requirements Document covering vision, 8 feature definitions, platform constraints, and success criteria', 'Subject Research + PCM detection running in every session'],
    tech: ['Claude Code', 'Anthropic API', 'Markdown specs'],
  },
  {
    name: 'Learn & Retain KB',
    category: 'Learn & Retain',
    status: 'Live',
    description: 'A persistent, agent-queryable knowledge base that ingests from YouTube playlists, AI tool output, and research reports. Synthesises across sources and surfaces structured knowledge to all pipeline components.',
    results: ['10 KB entries across YouTube + AI tool output sources', 'YouTube adapter: transcript → analysis → synthesis → KB entry', 'AI tool output adapter: paste or file → structured KB entry', 'Session-start context injection — KB summaries loaded at /good-morning'],
    tech: ['Python', 'Anthropic API (Haiku + Sonnet)', 'Obsidian vault', 'youtube-transcript-api'],
  },
];
---

<Page title="Projects" description="Projects built with the AI Agency Pipeline">
  <div class="mb-12">
    <h1 class="text-5xl font-bold text-white mb-4">Projects</h1>
    <p class="text-lg text-gray-400 max-w-2xl">
      Working software built with the pipeline. Every project is a real deliverable,
      not a demo.
    </p>
  </div>

  <div class="space-y-6">
    {projects.map(project => (
      <div class="border border-gray-800 rounded-lg p-6 hover:border-gray-700 transition-colors">
        <div class="flex items-start justify-between mb-4">
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h2 class="text-xl font-semibold text-white">{project.name}</h2>
              <span class={`text-xs px-2 py-0.5 rounded-full ${
                project.status === 'Live' ? 'bg-emerald-900 text-emerald-400' :
                project.status === 'Complete' ? 'bg-blue-900 text-blue-400' :
                'bg-gray-800 text-gray-500'
              }`}>{project.status}</span>
            </div>
            <p class="text-xs text-gray-600 uppercase tracking-widest">{project.category}</p>
          </div>
        </div>

        <p class="text-gray-400 text-sm mb-5">{project.description}</p>

        <div class="mb-4">
          <p class="text-xs text-gray-600 uppercase tracking-widest mb-2">Results</p>
          <ul class="space-y-1">
            {project.results.map(result => (
              <li class="text-sm text-gray-400 flex gap-2">
                <span class="text-emerald-500 flex-shrink-0">✓</span>
                {result}
              </li>
            ))}
          </ul>
        </div>

        <div class="flex flex-wrap gap-2">
          {project.tech.map(t => (
            <span class="text-xs px-2 py-1 bg-gray-900 border border-gray-800 text-gray-500 rounded">{t}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Page>
